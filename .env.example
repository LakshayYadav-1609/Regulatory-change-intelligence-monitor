# Copy this file to ".env" and fill in your own values.
# Never commit the real .env file (it is already in .gitignore).

# ── AI analysis (AI Analysis page) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email alerts (Alert Center page) ────────────────────────────
# Use a Gmail App Password, NOT your normal password.
# Create one at https://myaccount.google.com/apppasswords (needs 2-Step Verification).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your16charapppass
ALERT_RECIPIENT=team@company.com
